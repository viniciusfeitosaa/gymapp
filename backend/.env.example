# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/gymapp"

# JWT
JWT_SECRET="sua_chave_secreta_jwt"

# Frontend (CORS)
FRONTEND_URL="http://localhost:5173"

# Assinaturas App Store / Google Play (implementar ao publicar nas lojas)
# APPLE_APP_SHARED_SECRET=
# GOOGLE_PLAY_PACKAGE_NAME=com.gymcode.app

# YouTube Data API v3 (sugestões de vídeos de exercícios)
YOUTUBE_API_KEY="sua_chave_youtube_data_api_v3"

# Pexels API (opcional; se não configurar, usa fallback Wikimedia Commons)
PEXELS_API_KEY="sua_chave_pexels_api"
