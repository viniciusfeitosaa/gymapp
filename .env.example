# 🔒 NUNCA COMMITE ESTE ARQUIVO COM VALORES REAIS!
# Copie para .env: cp .env.example .env

# ==========================================
# GYM CODE — Homelab (Mac Mini / Docker)
# ==========================================

# ============ Cloudflare Tunnel (recomendado com CGNAT) ============
USE_CLOUDFLARE_TUNNEL=1
# Credenciais em infra/cloudflared/credentials.json (ver CLOUDFLARE_TUNNEL.md)
# CLOUDFLARE_TUNNEL_TOKEN=   # legado — não necessário com credentials.json
# CLOUDFLARE_API_TOKEN=      # opcional — para scripts/cloudflare-update-ingress.sh (www)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_TUNNEL_ID=

# ============ Domínio & Proxy (Caddy) ============
DOMAIN=:80
# DOMAIN=mygymcode.com
# ACME_EMAIL=seu@email.com

HTTP_PORT=80
HTTPS_PORT=443

FRONTEND_URL=https://mygymcode.com
# CORS_ORIGINS=https://mygymcode.com

# ============ Frontend (build) ============
VITE_API_URL=
VITE_APP_URL=http://192.168.18.142

# ============ PostgreSQL (container local) ============
POSTGRES_USER=gymapp
POSTGRES_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI
POSTGRES_DB=gymapp

# ============ Backend ============
NODE_ENV=production
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI

# ============ E-mail — Maddy (container maddy na stack) ============
MADDY_SMTP_PASS=GERE_UMA_SENHA_FORTE_AQUI
SMTP_HOST=maddy
SMTP_PORT=587
SMTP_USER=noreply@mygymcode.com
SMTP_PASS=GERE_UMA_SENHA_FORTE_AQUI
SMTP_FROM=noreply@mygymcode.com

# Relay de saída (obrigatório se operadora bloquear porta 25) — Brevo grátis ou Gmail
# SMTP_RELAY_HOST=smtp-relay.brevo.com
# SMTP_RELAY_PORT=587
# SMTP_RELAY_USER=
# SMTP_RELAY_PASS=

# ============ Mobile (Capacitor WebView) ============
# CAPACITOR_SERVER_URL=https://mygymcode.com/login
# CAPACITOR_APP_ID=com.mygymcode.app
# CAPACITOR_APP_NAME=Gym Code

# ============ Assinaturas (App Store / Google Play) ============
# SUBSCRIPTION_PRODUCT_ID=gymcode_pro_monthly
# APPLE_APP_SHARED_SECRET=
# APPLE_SANDBOX=1
# STORE_BILLING_SANDBOX_TRUST=1
#   ^ Com APPLE_SANDBOX=1: aceita transaction.id do StoreKit 2 no app (testes no simulador)
# GOOGLE_PLAY_PACKAGE_NAME=com.mygymcode.app
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXX
# PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.mygymcode.app

# CAPACITOR_USE_BUNDLED=1
# VITE_API_URL=https://mygymcode.com
# VITE_SUBSCRIPTION_PRODUCT_ID=gymcode_pro_monthly
# VITE_SUBSCRIPTION_PLAN_ID=monthly

# ============ APIs externas (opcional) ============
YOUTUBE_API_KEY=
PEXELS_API_KEY=
APP_TIMEZONE=America/Sao_Paulo
